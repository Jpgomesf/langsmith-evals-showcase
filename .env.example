# Copy to .env and fill in. `python-dotenv` loads this into the environment.

# --- LangSmith ---
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=evals-showcase
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com   # EU: https://eu.api.smith.langchain.com

# --- Models (provider-agnostic via langchain init_chat_model) ---
# Format is "<provider>:<model>", e.g. "anthropic:claude-sonnet-4-6" or "openai:gpt-4.1-mini".
# APP_MODEL is the system under test; JUDGE_MODEL powers the LLM-as-judge evaluators.
APP_MODEL=anthropic:claude-haiku-4-5
JUDGE_MODEL=anthropic:claude-sonnet-4-6

# --- Provider credentials (set whichever providers you reference above) ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Prefix applied to dataset names so this showcase's datasets are easy to find.
DATASET_PREFIX=evals-showcase
